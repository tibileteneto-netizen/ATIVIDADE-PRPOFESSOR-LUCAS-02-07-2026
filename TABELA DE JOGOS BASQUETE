-- ============================================
-- CONSULTAS ÚTEIS
-- ============================================

-- Consultar todos os jogos
SELECT * FROM jogos_basquete ORDER BY data_jogo DESC;

-- Próximos jogos agendados
SELECT 
    data_jogo,
    hora_jogo,
    time_mandante,
    time_visitante,
    arena,
    cidade
FROM jogos_basquete 
WHERE status = 'Agendado'
ORDER BY data_jogo ASC, hora_jogo ASC;

-- Jogos finalizados com resultado
SELECT 
    data_jogo,
    time_mandante || ' ' || pontos_mandante || ' x ' || pontos_visitante || ' ' || time_visitante as placar,
    arena,
    publico_presente
FROM jogos_basquete 
WHERE status = 'Finalizado'
ORDER BY data_jogo DESC;

-- Estatísticas por time mandante
SELECT 
    time_mandante,
    COUNT(*) as total_jogos,
    SUM(CASE WHEN pontos_mandante > pontos_visitante THEN 1 ELSE 0 END) as vitorias,
    SUM(CASE WHEN pontos_mandante < pontos_visitante THEN 1 ELSE 0 END) as derrotas,
    ROUND(AVG(pontos_mandante)::numeric, 2) as media_pontos_marcados,
    ROUND(AVG(pontos_visitante)::numeric, 2) as media_pontos_sofridos
FROM jogos_basquete 
WHERE status = 'Finalizado'
GROUP BY time_mandante
ORDER BY vitorias DESC;

-- Jogos do dia (útil para dashboard)
SELECT * 
FROM jogos_basquete 
WHERE data_jogo = CURRENT_DATE
ORDER BY hora_jogo;
