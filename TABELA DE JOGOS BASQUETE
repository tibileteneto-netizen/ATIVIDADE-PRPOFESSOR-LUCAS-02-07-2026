-- ============================================
-- TABELA DE JOGOS DE BASQUETE - SUPABASE
-- ============================================

-- 1. Criar a tabela principal
CREATE TABLE jogos_basquete (
    id BIGSERIAL PRIMARY KEY,
    data_jogo DATE NOT NULL,
    hora_jogo TIME DEFAULT '20:00:00',
    time_mandante VARCHAR(100) NOT NULL,
    time_visitante VARCHAR(100) NOT NULL,
    pontos_mandante INT DEFAULT NULL,
    pontos_visitante INT DEFAULT NULL,
    arena VARCHAR(150),
    cidade VARCHAR(100),
    liga VARCHAR(50) DEFAULT 'NBA',
    temporada VARCHAR(20) DEFAULT '2025-2026',
    status VARCHAR(20) DEFAULT 'Agendado' CHECK (status IN ('Agendado', 'Em Andamento', 'Finalizado', 'Cancelado', 'Adiado')),
    publico_presente INT DEFAULT NULL,
    observacoes TEXT,
    created_at TIMESTAMPTZ DEFAULT NOW(),
    updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- 2. Adicionar comentários para documentação
COMMENT ON TABLE jogos_basquete IS 'Tabela de jogos de basquete';
COMMENT ON COLUMN jogos_basquete.id IS 'Identificador único do jogo';
COMMENT ON COLUMN jogos_basquete.data_jogo IS 'Data do jogo';
COMMENT ON COLUMN jogos_basquete.status IS 'Status atual do jogo';

-- 3. Criar índices para performance
CREATE INDEX idx_jogos_data ON jogos_basquete(data_jogo);
CREATE INDEX idx_jogos_status ON jogos_basquete(status);
CREATE INDEX idx_jogos_liga ON jogos_basquete(liga);
CREATE INDEX idx_jogos_mandante ON jogos_basquete(time_mandante);
CREATE INDEX idx_jogos_visitante ON jogos_basquete(time_visitante);

-- 4. Habilitar Row Level Security (RLS) - Segurança do Supabase
ALTER TABLE jogos_basquete ENABLE ROW LEVEL SECURITY;

-- 5. Políticas de acesso (ajuste conforme necessidade)
-- Permitir leitura pública
CREATE POLICY "Permitir leitura pública" 
ON jogos_basquete 
FOR SELECT 
USING (true);

-- Permitir inserção apenas para usuários autenticados
CREATE POLICY "Permitir inserção para autenticados" 
ON jogos_basquete 
FOR INSERT 
WITH CHECK (auth.role() = 'authenticated');

-- Permitir atualização apenas para usuários autenticados
CREATE POLICY "Permitir atualização para autenticados" 
ON jogos_basquete 
FOR UPDATE 
USING (auth.role() = 'authenticated')
WITH CHECK (auth.role() = 'authenticated');

-- Permitir exclusão apenas para usuários autenticados
CREATE POLICY "Permitir exclusão para autenticados" 
ON jogos_basquete 
FOR DELETE 
USING (auth.role() = 'authenticated');

-- 6. Trigger para atualizar updated_at automaticamente
CREATE OR REPLACE FUNCTION update_updated_at_column()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = NOW();
    RETURN NEW;
END;
$$ language 'plpgsql';

CREATE TRIGGER update_jogos_basquete_updated_at
    BEFORE UPDATE ON jogos_basquete
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();

